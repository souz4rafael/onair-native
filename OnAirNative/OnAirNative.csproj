<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- Target Windows 10 2004 (19041) minimum — required for WinUI 3 -->
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>OnAirNative</RootNamespace>
    <AssemblyName>OnAirNative</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x64</Platforms>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <!-- Unpackaged deployment — no MSIX required -->
    <WindowsPackageType>None</WindowsPackageType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>preview</LangVersion>
    <!-- Suppress the auto-generated XAML break-on-exception which fires in debug -->
    <DefineConstants>$(DefineConstants);DISABLE_XAML_GENERATED_BREAK_ON_UNHANDLED_EXCEPTION</DefineConstants>

    <!--
      Normalize source paths embedded in the binary/PDB so crash stack traces
      don't leak the build machine's username and folder layout. Real paths
      (C:\Users\...\OnAirNative\) become /src\... in shipped stack traces.
    -->
    <DeterministicSourcePaths>true</DeterministicSourcePaths>
    <PathMap>$(MSBuildProjectDirectory)=/src</PathMap>
  </PropertyGroup>

  <ItemGroup>
    <!-- App icon — copied to output folder so TrayService can load it at runtime -->
    <Content Include="Assets\app-icon.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <!-- Windows App SDK — provides WinUI 3, AppWindow, WebView2, etc. -->
    <!-- Run: dotnet add package Microsoft.WindowsAppSDK -->
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="2.1.3" />
    <!-- Windows SDK build tools (required by WinUI 3 codegen) -->
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.28000.1839" PrivateAssets="all" />

    <!-- MVVM source generators: [ObservableProperty], [RelayCommand] -->
    <!-- Run: dotnet add package CommunityToolkit.Mvvm -->
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.3.2" />

    <!-- NAudio: WASAPI microphone capture + loopback (system audio) -->
    <!-- Run: dotnet add package NAudio -->
    <PackageReference Include="NAudio" Version="2.2.1" />

    <!-- Whisper.net: in-process Whisper transcription (no Python subprocess) -->
    <!-- Run: dotnet add package Whisper.net && dotnet add package Whisper.net.Runtime -->
    <PackageReference Include="Whisper.net" Version="1.7.3" />
    <PackageReference Include="Whisper.net.Runtime" Version="1.7.3" />

    <!-- DPAPI secret-at-rest encryption for API keys (ProtectedData) -->
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="8.0.0" />
  </ItemGroup>

  <!--
    Visual C++ Runtime — app-local deployment.
    WinUI 3 / Windows App SDK self-contained does NOT bundle the VC++ Runtime,
    so on a clean machine without the VC++ Redistributable the native WinUI
    components fail to load and the app exits silently with no error.
    Copying these redistributable DLLs next to the exe makes the app truly
    self-contained. Source: the VC Tools redist dir when a VS build env is
    present, otherwise the system copy.
  -->
  <Target Name="CopyVCRuntime" AfterTargets="Build;Publish">
    <PropertyGroup>
      <_VCRedistX64>$(VCToolsRedistDir)x64\Microsoft.VC143.CRT\</_VCRedistX64>
    </PropertyGroup>
    <ItemGroup>
      <_VCRuntimeFiles Condition="Exists('$(_VCRedistX64)')" Include="$(_VCRedistX64)vcruntime140.dll;$(_VCRedistX64)vcruntime140_1.dll;$(_VCRedistX64)msvcp140.dll" />
      <_VCRuntimeFiles Condition="!Exists('$(_VCRedistX64)')" Include="$(WINDIR)\System32\vcruntime140.dll;$(WINDIR)\System32\vcruntime140_1.dll;$(WINDIR)\System32\msvcp140.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_VCRuntimeFiles)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" Condition="'@(_VCRuntimeFiles)' != ''" />
    <Copy SourceFiles="@(_VCRuntimeFiles)" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" Condition="'$(PublishDir)' != '' and '@(_VCRuntimeFiles)' != ''" />
  </Target>

  <!--
    Deploy the compiled XAML resource index (OnAirNative.pri) to the publish
    folder. `dotnet publish` to a custom output directory does NOT copy the
    PRI file, so at runtime LoadComponent cannot find the compiled .xbf XAML
    and every Window() throws XamlParseException — the app installs fine but
    exits silently / crashes on launch. Copy the build-produced PRI into the
    publish output to fix this.
  -->
  <Target Name="CopyPriToPublish" AfterTargets="Publish" Condition="'$(PublishDir)' != ''">
    <Copy SourceFiles="$(OutDir)$(AssemblyName).pri"
          DestinationFolder="$(PublishDir)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(OutDir)$(AssemblyName).pri')" />
  </Target>

</Project>
