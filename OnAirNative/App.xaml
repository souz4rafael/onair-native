<Application
    x:Class="OnAirNative.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Overlay dark palette -->
            <Color x:Key="OverlayBgColor">#B31A1A2E</Color>
            <Color x:Key="OverlayHeaderBgColor">#CC1A1A2E</Color>
            <SolidColorBrush x:Key="OverlayBgBrush" Color="{StaticResource OverlayBgColor}"/>
            <SolidColorBrush x:Key="OverlayHeaderBgBrush" Color="{StaticResource OverlayHeaderBgColor}"/>
            <SolidColorBrush x:Key="OverlayTextBrush" Color="#F0F0F0"/>
            <SolidColorBrush x:Key="OverlaySubtleBrush" Color="#A0A0A0"/>
            <SolidColorBrush x:Key="AccentBlueBrush" Color="#4A90D9"/>

            <!-- Pill RadioButton style — checked state colour handled in OverlayWindow code-behind -->
            <Style x:Key="PillRadioButtonStyle" TargetType="RadioButton">
                <Setter Property="Foreground" Value="#AAFFFFFF"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Padding" Value="14,4"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="CornerRadius" Value="10"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
