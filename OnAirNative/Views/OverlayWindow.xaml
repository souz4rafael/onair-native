<Window
    x:Class="OnAirNative.Views.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OnAirNative.Views"
    xmlns:helpers="using:OnAirNative.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="onAIr">

    <!--
        Background="Transparent" alone does not make a WinUI 3 window transparent.
        The code-behind calls WindowService.MakeTransparent(hwnd) via DWM to achieve
        true compositor transparency. The root Grid background is set to a semi-opaque
        dark brush defined in App.xaml resources.
    -->
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <helpers:BoolToVisibilityConverter   x:Key="BoolToVisibilityConverter"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header bar: mode indicator + lock badge ═════════════════════ -->
        <Grid Grid.Row="0"
              x:Name="HeaderBar"
              Background="{StaticResource OverlayHeaderBgBrush}"
              Padding="8,4,8,4"
              CornerRadius="8,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Current mode label (read-only — changed from Controller) -->
            <TextBlock x:Name="CurrentModeLabel"
                       Text="● Script"
                       Foreground="#DDDDFF"
                       FontSize="12"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <!-- Lock/Unlock status -->
            <Border x:Name="MoveBadge"
                    Grid.Column="1"
                    Background="#333355"
                    CornerRadius="4"
                    Padding="6,2"
                    ToolTipService.ToolTip="Toggle locked/unlocked in the Controller">
                <TextBlock x:Name="MoveBadgeText"
                           Text="🔓 UNLOCKED"
                           FontSize="10"
                           Foreground="#AAAACC"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <!-- ═══ Content panels (one visible at a time) ═══════════════════════ -->
        <Grid Grid.Row="1">

            <!-- ─── Script / Teleprompter panel ─────────────────────────────── -->
            <ScrollViewer x:Name="ScriptScrollViewer"
                          Background="{StaticResource OverlayBgBrush}"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Enabled"
                          Visibility="Visible">
                <TextBlock x:Name="ScriptTextBlock"
                           Padding="16,12,16,24"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource OverlayTextBrush}"
                           FontSize="22"
                           LineHeight="34"
                           FontFamily="Segoe UI"
                           IsTextSelectionEnabled="False"
                           Text=""/>
            </ScrollViewer>

            <!-- ─── Q&A panel ─────────────────────────────────────────────── -->
            <Border x:Name="QaPanel"
                    Background="{StaticResource OverlayBgBrush}"
                    Padding="16,12"
                    Visibility="Collapsed">
                <StackPanel Spacing="10">

                    <!-- Status (recording / transcribing / getting answer) -->
                    <TextBlock x:Name="QaStatusText"
                               Foreground="#A0A0A0"
                               FontSize="13"
                               Text=""
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>

                    <!-- Transcribed question (italic, subtle) -->
                    <TextBlock x:Name="QaQuestionText"
                               Foreground="#9090A0"
                               FontSize="14"
                               FontStyle="Italic"
                               TextWrapping="Wrap"
                               Text=""
                               Visibility="Collapsed"/>

                    <!-- AI answer (prominent) -->
                    <TextBlock x:Name="QaAnswerText"
                               Foreground="{StaticResource OverlayTextBrush}"
                               FontSize="18"
                               LineHeight="27"
                               TextWrapping="Wrap"
                               Text=""
                               Visibility="Collapsed"/>

                    <!-- Busy indicator -->
                    <ProgressRing x:Name="QaBusy"
                                  IsActive="False"
                                  Width="32" Height="32"
                                  Foreground="#4A90D9"
                                  Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>
